
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      // Allow read and write access for testing purposes.
      // WARNING: This is insecure for production. Revert to a secure rule
      // like "if request.auth != null;" after debugging.
      allow read, write: if true;
    }
  }
}

